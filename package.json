{
  "name": "vdrive",
  "version": "1.0.0",
  "description": "End-to-End Recruitment Operations Dashboard - Streamline hiring with AI-powered candidate matching and webhook orchestration",
  "author": "Aayush Kumar Dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aayushkumardev09-creator/vdrive.git"
  },
  "bugs": {
    "url": "https://github.com/aayushkumardev09-creator/vdrive/issues"
  },
  "homepage": "https://github.com/aayushkumardev09-creator/vdrive#readme",
  "keywords": [
    "recruitment",
    "hiring",
    "dashboard",
    "candidate-tracking",
    "ai",
    "supabase",
    "react",
    "typescript",
    "vite",
    "tailwind"
  ],
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite --port=3000 --host=0.0.0.0",
    "dev:backend": "cd backend && npm run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "vite build",
    "build:backend": "cd backend && npm run build",
    "start": "cd backend && npm start",
    "preview": "vite preview",
    "clean": "rm -rf dist backend/dist",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\" \"backend/src/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css}\" \"backend/src/**/*.{ts,json}\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "papaparse": "^5.5.3",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.15.0",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/papaparse": "^5.5.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "esbuild": "^0.25.0",
    "prettier": "^3.1.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=10.0.0"
  }
}
