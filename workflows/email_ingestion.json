                            "sourceCode": {
                              "code": "export const code = async (inputs) => {\n  try {\n    let raw = inputs.ai_response;\n\n    // Step 1: remove wrapping if it's stringified JSON\n    if (typeof raw !== \"string\") {\n      raw = JSON.stringify(raw);\n    }\n\n    // Step 2: extract JSON inside string\n    const match = raw.match(/\\{[\\s\\S]*\\}/);\n\n    if (!match) {\n      return {\n        error: \"No JSON found\",\n        raw_output: raw\n      };\n    }\n\n    let cleaned = match[0];\n\n    // Step 3: parse JSON safely\n    const parsed = JSON.parse(cleaned);\n\n    return parsed;\n\n  } catch (err) {\n    return {\n      error: \"Parsing failed\",\n      raw_output: inputs.ai_response\n    };\n  }\n};",
